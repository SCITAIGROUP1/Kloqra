{
  "name": "kloqra",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "turbo run build",
    "predev:apps": "bash scripts/predev-bootstrap.sh && pnpm build --filter=@kloqra/contracts --filter=@kloqra/ui --filter=@kloqra/web-shared && pnpm prisma:generate",
    "dev": "pnpm run predev:apps && pnpm --parallel --filter @kloqra/api --filter @kloqra/client --filter @kloqra/admin dev",
    "dev:shared": "pnpm --parallel --filter @kloqra/contracts --filter @kloqra/ui --filter @kloqra/web-shared dev",
    "check:bundle-budget": "node scripts/check-bundle-budget.mjs",
    "dev:api": "pnpm --filter @kloqra/api dev",
    "dev:client": "pnpm --filter @kloqra/client dev",
    "dev:admin": "pnpm --filter @kloqra/admin dev",
    "dev:platform": "pnpm --filter @kloqra/platform-admin dev",
    "dev:web": "pnpm --filter @kloqra/web dev",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:reset": "docker compose down -v && docker compose up -d",
    "local": "bash scripts/local.sh",
    "local:docker": "bash scripts/local-docker.sh",
    "local:native": "bash scripts/local-native.sh",
    "serve": "bash scripts/serve.sh",
    "serve:docker": "bash scripts/local-docker.sh --install",
    "serve:native": "bash scripts/local-native.sh --install",
    "serve:split": "bash scripts/dev-split-native.sh start",
    "serve:split:stop": "bash scripts/dev-split-native.sh stop",
    "serve:split:status": "bash scripts/dev-split-native.sh status",
    "serve:split:restart": "bash scripts/dev-split-native.sh restart",
    "lint": "turbo run lint",
    "lint:fix": "eslint . --fix",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "node -e \"const {existsSync}=require('fs');const {execSync}=require('child_process');if(existsSync('node_modules/husky'))execSync('husky',{stdio:'inherit'})\"",
    "test": "turbo run test",
    "test:ui": "pnpm --filter @kloqra/api test:ui",
    "test:dashboard": "node scripts/test-dashboard.mjs --open",
    "test:coverage": "pnpm build --filter=@kloqra/contracts --filter=@kloqra/web-shared && pnpm --filter @kloqra/api test:coverage && pnpm --filter @kloqra/contracts test -- --coverage && pnpm --filter @kloqra/ui test -- --coverage && pnpm --filter @kloqra/web-shared test",
    "test:integration": "pnpm --filter @kloqra/api test:e2e",
    "test:e2e": "bash scripts/test-prepush.sh",
    "test:prepush": "bash scripts/test-prepush.sh",
    "test:prepr": "bash scripts/test-prepr.sh",
    "prisma:generate": "pnpm --filter @kloqra/api prisma:generate",
    "prisma:migrate": "pnpm --filter @kloqra/api prisma:migrate",
    "prisma:seed": "pnpm --filter @kloqra/api prisma:seed",
    "prisma:validate": "pnpm --filter @kloqra/api prisma:validate",
    "deploy:migrate": "bash scripts/deploy/migrate.sh",
    "deploy:seed": "bash scripts/deploy/seed.sh",
    "deploy:db": "bash scripts/deploy/db.sh",
    "deploy:smoke": "bash scripts/deploy/smoke.sh",
    "deploy:secrets": "bash scripts/deploy/generate-secrets.sh",
    "deploy:railway": "railway",
    "deploy:vercel": "vercel"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@kloqra/config-eslint": "workspace:*",
    "@kloqra/config-prettier": "workspace:*",
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "@railway/cli": "^4.6.0",
    "eslint": "^9.17.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.3.0",
    "prettier": "^3.4.2",
    "turbo": "^2.9.17",
    "typescript": "^5.7.2",
    "vercel": "^41.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs,json,md}": [
      "prettier --write",
      "eslint --fix"
    ]
  }
}
