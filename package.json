{
  "name": "kloqra",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "turbo run build",
    "predev": "pnpm --filter @kloqra/contracts build && pnpm --filter @kloqra/ui build && pnpm prisma:generate",
    "dev": "pnpm --parallel --filter @kloqra/api --filter @kloqra/client --filter @kloqra/admin dev",
    "serve": "bash scripts/serve.sh",
    "lint": "turbo run lint",
    "lint:fix": "eslint . --fix",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "test": "turbo run test",
    "test:ui": "pnpm --filter @kloqra/api test:ui",
    "test:dashboard": "node scripts/test-dashboard.mjs --open",
    "test:coverage": "pnpm --filter @kloqra/contracts build && pnpm --filter @kloqra/api test:coverage && pnpm --filter @kloqra/contracts test -- --coverage && pnpm --filter @kloqra/ui test -- --coverage && pnpm --filter @kloqra/web-shared test",
    "test:integration": "pnpm --filter @kloqra/api test:e2e",
    "test:e2e": "bash scripts/test-prepush.sh",
    "test:prepush": "bash scripts/test-prepush.sh",
    "prisma:generate": "pnpm --filter @kloqra/api prisma:generate",
    "prisma:migrate": "pnpm --filter @kloqra/api prisma:migrate",
    "prisma:seed": "pnpm --filter @kloqra/api prisma:seed",
    "prisma:validate": "pnpm --filter @kloqra/api prisma:validate",
    "deploy:migrate": "bash scripts/deploy/migrate.sh",
    "deploy:smoke": "bash scripts/deploy/smoke.sh",
    "deploy:secrets": "bash scripts/deploy/generate-secrets.sh",
    "deploy:railway": "railway",
    "deploy:vercel": "vercel"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@kloqra/config-eslint": "workspace:*",
    "@kloqra/config-prettier": "workspace:*",
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "@railway/cli": "^4.6.0",
    "eslint": "^9.17.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.3.0",
    "prettier": "^3.4.2",
    "turbo": "^2.9.17",
    "typescript": "^5.7.2",
    "vercel": "^41.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs,json,md}": [
      "prettier --write",
      "eslint --fix"
    ]
  }
}
