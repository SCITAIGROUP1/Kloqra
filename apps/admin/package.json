    "lucide-react": "^0.469.0",
    "next": "^15.1.2",
    "next-themes": "^0.4.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-grid-layout": "^1.4.4",
    "sonner": "^2.0.7",
    "zod": "^3.24.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@kloqra/config-typescript": "workspace:*",
    "@testing-library/react": "^16.1.0",
    "@next/bundle-analyzer": "^15.1.2",
    "@playwright/test": "^1.49.1",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@types/react-grid-layout": "^1.3.5",
    "jsdom": "^26.0.0",
    "recharts": "^2.15.4",
    "tailwindcss": "^4.0.0",
    "tw-animate-css": "^1.2.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
