{
  "name": "@kloqra/admin",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "node ../../scripts/ensure-web-shared-built.mjs",
    "dev": "next dev --turbo -p 3002",
    "build": "next build",
    "analyze": "ANALYZE=true next build",
    "start": "next start -p 3002",
