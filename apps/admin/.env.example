NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
NEXT_PUBLIC_AUTH_SCOPE=admin
# Optional — used when building share links (defaults to http://localhost:3002)
NEXT_PUBLIC_ADMIN_URL=http://localhost:3002
# Show /signup link on login when API self-serve is enabled (SaaS-F20)
# NEXT_PUBLIC_SELF_SERVE_SIGNUP=true
# Signup/billing plans are loaded from GET /public/plans (starter, pro) — no frontend env needed
# Legal document URLs (SaaS-F23)
# NEXT_PUBLIC_LEGAL_TOS_URL=https://kloqra.com/terms
# NEXT_PUBLIC_LEGAL_PRIVACY_URL=https://kloqra.com/privacy
# NEXT_PUBLIC_LEGAL_REFUND_URL=https://kloqra.com/refund
