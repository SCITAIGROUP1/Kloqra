{
  "name": "@kloqra/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prebuild": "pnpm -C ../../packages/contracts run build",
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "lint": "eslint .",
    "typecheck": "prisma generate && tsc -p tsconfig.json --noEmit && tsc -p tsconfig.seed.json --noEmit && tsc -p tsconfig.e2e.json --noEmit",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage && node scripts/check-module-coverage.mjs",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "prisma:generate": "prisma generate",
    "postinstall": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "preprisma:seed": "pnpm -C ../../packages/contracts run build",
    "prisma:seed": "prisma generate && tsx --tsconfig tsconfig.seed.json prisma/seed.ts",
    "prisma:validate": "prisma validate"
  },
  "prisma": {
    "seed": "tsx --tsconfig tsconfig.seed.json prisma/seed.ts"
  },
  "dependencies": {
    "@kloqra/contracts": "workspace:*",
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^6.1.0",
    "@types/nodemailer": "^8.0.0",
    "archiver": "^7.0.1",
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.7",
    "exceljs": "^4.4.0",
    "helmet": "^8.2.0",
    "ioredis": "^5.4.2",
    "nodemailer": "^8.0.10",
    "otplib": "^13.4.1",
    "pdfkit": "^0.15.2",
    "prisma": "^6.1.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@kloqra/config-typescript": "workspace:*",
    "@nestjs/cli": "^10.4.9",
    "@nestjs/testing": "^10.4.15",
    "@swc/core": "^1.15.41",
    "@types/archiver": "^6.0.3",
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^5.0.0",
    "@types/helmet": "^4.0.0",
    "@types/node": "^22.10.2",
    "@types/pdfkit": "^0.13.8",
    "@types/supertest": "^6.0.2",
    "@vitest/coverage-v8": "^2.1.8",
    "@vitest/ui": "^2.1.8",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "unplugin-swc": "^1.5.9",
    "vitest": "^2.1.8"
  }
}
