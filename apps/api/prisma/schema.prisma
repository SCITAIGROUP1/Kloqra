generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String            @id @default(uuid())
  email                 String            @unique
  passwordHash          String            @map("password_hash")
  name                  String
  defaultHourlyRate     Decimal?          @map("default_hourly_rate") @db.Decimal(10, 2)
  preferences           Json              @default("{}")
  createdAt             DateTime          @default(now()) @map("created_at")
  updatedAt             DateTime          @updatedAt @map("updated_at")
  memberships           WorkspaceMember[]
  timeLogs              TimeLog[]
  hourlyRates           HourlyRate[]
  teamMembers           TeamMember[]
  projectInvitesCreated ProjectInvite[]   @relation("ProjectInvitesCreated")
  refreshTokens         RefreshToken[]
  timesheetPeriods      TimesheetPeriod[]

  @@map("users")
}

model Workspace {
  id              String            @id @default(uuid())
  name            String
  slug            String            @unique
  settings        Json              @default("{}")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  members         WorkspaceMember[]
  projects        Project[]
  categories      Category[]
  hourlyRates     HourlyRate[]
  exportPresets   ExportPreset[]
  exportSchedules ExportSchedule[]
  reportShares    ReportShare[]

  @@map("workspaces")
}

/// Workspace-scoped category that groups tasks (e.g. "Software Development",
/// "UI/UX Design", "Meetings"). Managed by Admin only.
model Category {
  id          String    @id @default(uuid())
  workspaceId String    @map("workspace_id")
  name        String
  description String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tasks       Task[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
  @@map("categories")
}

model WorkspaceMember {
  id          String    @id @default(uuid())
  workspaceId String    @map("workspace_id")
  userId      String    @map("user_id")
  role        String
  createdAt   DateTime  @default(now()) @map("created_at")
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@map("workspace_members")
}

model Project {
  id                       String            @id @default(uuid())
  workspaceId              String            @map("workspace_id")
  name                     String
  color                    String            @default("#6366f1")
  clientName               String?           @map("client_name")
  budgetHours              Decimal?          @map("budget_hours") @db.Decimal(10, 2)
  isActive                 Boolean           @default(true) @map("is_active")
  timesheetApprovalEnabled Boolean           @default(false) @map("timesheet_approval_enabled")
  timesheetApprovalPeriod  String?           @map("timesheet_approval_period")
  createdAt                DateTime          @default(now()) @map("created_at")
  updatedAt                DateTime          @updatedAt @map("updated_at")
  workspace                Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  team                     Team?
  tasks                    Task[]
  hourlyRates              HourlyRate[]
  invites                  ProjectInvite[]
  timesheetPeriods         TimesheetPeriod[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
  @@map("projects")
}

/// Each project has exactly one team of members who may log time on it.
model Team {
  id        String       @id @default(uuid())
  projectId String       @unique @map("project_id")
  createdAt DateTime     @default(now()) @map("created_at")
  project   Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  members   TeamMember[]

  @@map("teams")
}

model TeamMember {
  id        String   @id @default(uuid())
  teamId    String   @map("team_id")
  userId    String   @map("user_id")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([userId])
  @@map("team_members")
}

model ProjectInvite {
  id          String    @id @default(uuid())
  projectId   String    @map("project_id")
  token       String    @unique
  email       String?
  expiresAt   DateTime  @map("expires_at")
  acceptedAt  DateTime? @map("accepted_at")
  createdById String    @map("created_by_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy   User      @relation("ProjectInvitesCreated", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("project_invites")
}

model Task {
  id              String    @id @default(uuid())
  projectId       String    @map("project_id")
  categoryId      String    @map("category_id")
  taskName        String    @map("task_name")
  billableDefault Boolean   @default(true) @map("billable_default")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  project         Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  category        Category  @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  timeLogs        TimeLog[]

  @@index([projectId])
  @@index([categoryId])
  @@map("tasks")
}

model TimeLog {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  taskId      String   @map("task_id")
  startTime   DateTime @map("start_time")
  endTime     DateTime @map("end_time")
  durationSec Int      @map("duration_sec")
  description String?
  isBillable  Boolean  @default(true) @map("is_billable")
  source      String
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([userId, startTime])
  @@index([taskId, startTime])
  @@index([startTime])
  @@map("time_logs")
}

model HourlyRate {
  id            String    @id @default(uuid())
  workspaceId   String    @map("workspace_id")
  userId        String?   @map("user_id")
  projectId     String?   @map("project_id")
  rate          Decimal   @db.Decimal(10, 2)
  effectiveFrom DateTime  @map("effective_from")
  createdAt     DateTime  @default(now()) @map("created_at")
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user          User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project       Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([workspaceId, effectiveFrom])
  @@map("hourly_rates")
}

model ExportPreset {
  id          String    @id @default(uuid())
  workspaceId String    @map("workspace_id")
  name        String
  body        Json
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, name])
  @@index([workspaceId])
  @@map("export_presets")
}

model ExportSchedule {
  id               String    @id @default(uuid())
  workspaceId      String    @map("workspace_id")
  name             String
  frequency        String
  recipientEmails  String[]  @map("recipient_emails")
  body             Json
  enabled          Boolean   @default(true)
  nextRunAt        DateTime  @map("next_run_at")
  lastRunAt        DateTime? @map("last_run_at")
  lastRunStatus    String?   @map("last_run_status")
  lastRunError     String?   @map("last_run_error")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  workspace        Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([nextRunAt, enabled])
  @@map("export_schedules")
}

model ReportShare {
  id          String    @id @default(uuid())
  workspaceId String    @map("workspace_id")
  token       String    @unique
  body        Json
  expiresAt   DateTime  @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@map("report_shares")
}

/// Persisted refresh tokens — enables server-side revocation and rotation.
/// A token is "valid" if revokedAt IS NULL and expiresAt > NOW().
model RefreshToken {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  workspaceId String    @map("workspace_id")
  tokenHash   String    @unique @map("token_hash")  // SHA-256 of the raw JWT
  family      String    // Random family ID — rotating every refresh; used for replay detection
  revokedAt   DateTime? @map("revoked_at")
  expiresAt   DateTime  @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}

/// Represents a timesheet approval period for a user on a project.
/// States: DRAFT → SUBMITTED → APPROVED | REJECTED → SUBMITTED …
model TimesheetPeriod {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  workspaceId String    @map("workspace_id")
  projectId   String    @map("project_id")
  periodStart DateTime  @map("period_start")
  periodEnd   DateTime  @map("period_end")
  status      String    @default("DRAFT") // DRAFT | SUBMITTED | APPROVED | REJECTED
  note        String?
  reviewNote  String?   @map("review_note")
  reviewedBy  String?   @map("reviewed_by")
  submittedAt DateTime? @map("submitted_at")
  reviewedAt  DateTime? @map("reviewed_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId, periodStart])
  @@index([workspaceId, status])
  @@index([periodStart])
  @@index([projectId])
  @@map("timesheet_periods")
}

model TimeLogAuditEvent {
  id          String   @id @default(uuid())
  workspaceId String   @map("workspace_id")
  timeLogId   String   @map("time_log_id")
  entryUserId String   @map("entry_user_id")
  actorId     String   @map("actor_id")
  action      String
  before      Json?
  after       Json?
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([timeLogId, createdAt])
  @@index([workspaceId, createdAt])
  @@map("time_log_audit_events")
}
