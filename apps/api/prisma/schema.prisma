generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String            @id @default(uuid())
  email                 String            @unique
  passwordHash          String            @map("password_hash")
  name                  String
  firstName             String?           @map("first_name")
  lastName              String?           @map("last_name")
  phone                 String?
  location              String?
  avatarUrl             String?           @map("avatar_url")
  jobTitle              String?           @map("job_title")
  department            String?
  workStartDate         DateTime?         @map("work_start_date") @db.Date
  totpSecret            String?           @map("totp_secret")
  totpEnabledAt         DateTime?         @map("totp_enabled_at")
  mustChangePassword    Boolean           @default(false) @map("must_change_password")
  emailVerifiedAt       DateTime?         @map("email_verified_at")
  emailVerificationTokenHash String?      @map("email_verification_token_hash")
  emailVerificationExpiresAt DateTime?     @map("email_verification_expires_at")
  passwordResetTokenHash String?          @map("password_reset_token_hash")
  passwordResetExpiresAt DateTime?        @map("password_reset_expires_at")
  defaultHourlyRate     Decimal?          @map("default_hourly_rate") @db.Decimal(10, 2)
  preferences           Json              @default("{}")
  createdAt             DateTime          @default(now()) @map("created_at")
  updatedAt             DateTime          @updatedAt @map("updated_at")
  memberships           WorkspaceMember[]
  timeLogs              TimeLog[]
  hourlyRates           HourlyRate[]
  teamMembers           TeamMember[]
  projectInvitesCreated ProjectInvite[]   @relation("ProjectInvitesCreated")
  refreshTokens         RefreshToken[]
  timesheetPeriods      TimesheetPeriod[]
  timesheetAmendments   TimesheetAmendmentRequest[]
  taskAssignees         TaskAssignee[]
  projectColors         UserProjectColor[]
  notifications         Notification[]
  exportJobs            ExportJob[]
  jiraEmail             String?           @map("jira_email")

  @@map("users")
}

model Workspace {
  id              String            @id @default(uuid())
  name            String
  slug            String            @unique
  settings        Json              @default("{}")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  members         WorkspaceMember[]
  projects        Project[]
  categories      Category[]
  hourlyRates     HourlyRate[]
  exportPresets   ExportPreset[]
  exportSchedules ExportSchedule[]
  exportJobs      ExportJob[]
  reportShares    ReportShare[]
  reportingApiCredentials ReportingApiCredential[]
  widgetShares    WidgetShare[]
  notifications   Notification[]

  @@map("workspaces")
}

model Notification {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  workspaceId String    @map("workspace_id")
  type        String
  title       String
  body        String
  metadata    Json      @default("{}")
  readAt      DateTime? @map("read_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([userId, workspaceId, createdAt(sort: Desc)])
  @@index([userId, workspaceId, readAt])
  @@index([metadata], type: Gin)
  @@map("notifications")
}

/// Workspace-scoped category that groups tasks (e.g. "Software Development",
/// "UI/UX Design", "Meetings"). Managed by Admin only.
model Category {
  id          String    @id @default(uuid())
  workspaceId String    @map("workspace_id")
  name        String
  description String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tasks       Task[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
  @@map("categories")
}

model WorkspaceMember {
  id          String    @id @default(uuid())
  workspaceId String    @map("workspace_id")
  userId      String    @map("user_id")
  role        String
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@map("workspace_members")
}

model Project {
  id                       String            @id @default(uuid())
  workspaceId              String            @map("workspace_id")
  name                     String
  color                    String            @default("#6366f1")
  clientName               String?           @map("client_name")
  budgetHours              Decimal?          @map("budget_hours") @db.Decimal(10, 2)
  isActive                 Boolean           @default(true) @map("is_active")
  timesheetApprovalEnabled             Boolean           @default(false) @map("timesheet_approval_enabled")
  timesheetApprovalPeriod              String?           @map("timesheet_approval_period")
  timesheetApprovalEnabledAt           DateTime?         @map("timesheet_approval_enabled_at")
  timesheetApprovalPeriodEffectiveAt   DateTime?         @map("timesheet_approval_period_effective_at")
  createdAt                            DateTime          @default(now()) @map("created_at")
  updatedAt                DateTime          @updatedAt @map("updated_at")
  workspace                Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  team                     Team?
  tasks                    Task[]
  hourlyRates              HourlyRate[]
  invites                  ProjectInvite[]
  timesheetPeriods         TimesheetPeriod[]
  userColors               UserProjectColor[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
  @@map("projects")
}

/// Each project has exactly one team of members who may log time on it.
model Team {
  id        String       @id @default(uuid())
  projectId String       @unique @map("project_id")
  createdAt DateTime     @default(now()) @map("created_at")
  project   Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  members   TeamMember[]

  @@map("teams")
}

model TeamMember {
  id        String   @id @default(uuid())
  teamId    String   @map("team_id")
  userId    String   @map("user_id")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([userId])
  @@map("team_members")
}

model ProjectInvite {
  id          String    @id @default(uuid())
  projectId   String    @map("project_id")
  token       String    @unique
  email       String?
  expiresAt   DateTime  @map("expires_at")
  acceptedAt  DateTime? @map("accepted_at")
  createdById String    @map("created_by_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy   User      @relation("ProjectInvitesCreated", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([email])
  @@map("project_invites")
}

model Task {
  id              String    @id @default(uuid())
  projectId       String    @map("project_id")
  categoryId      String    @map("category_id")
  taskName        String    @map("task_name")
  billableDefault Boolean   @default(true) @map("billable_default")
  isCommon        Boolean   @default(true) @map("is_common")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  project         Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  category        Category  @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  timeLogs        TimeLog[]
  assignees       TaskAssignee[]

  @@index([projectId])
  @@index([categoryId])
  @@map("tasks")
}

model TaskAssignee {
  id        String   @id @default(uuid())
  taskId    String   @map("task_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
  @@index([userId])
  @@map("task_assignees")
}

model UserProjectColor {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  projectId String   @map("project_id")
  color     String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@map("user_project_colors")
}

model TimeLog {
  id          String   @default(uuid())
  userId      String   @map("user_id")
  taskId      String   @map("task_id")
  startTime   DateTime @map("start_time")
  endTime     DateTime @map("end_time")
  durationSec Int      @map("duration_sec")
  description String?
  isBillable  Boolean  @default(true) @map("is_billable")
  source      String
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@id([id, startTime])
  @@index([userId, startTime])
  @@index([taskId, startTime])
  @@index([startTime])
  @@map("time_logs")
}

model HourlyRate {
  id            String    @id @default(uuid())
  workspaceId   String    @map("workspace_id")
  userId        String?   @map("user_id")
  projectId     String?   @map("project_id")
  rate          Decimal   @db.Decimal(10, 2)
  effectiveFrom DateTime  @map("effective_from")
  createdAt     DateTime  @default(now()) @map("created_at")
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user          User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project       Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([workspaceId, effectiveFrom])
  @@unique([workspaceId, userId, projectId, effectiveFrom])
  @@map("hourly_rates")
}

model ExportPreset {
  id          String    @id @default(uuid())
  workspaceId String    @map("workspace_id")
  name        String
  body        Json
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, name])
  @@index([workspaceId])
  @@map("export_presets")
}

model ExportSchedule {
  id               String    @id @default(uuid())
  workspaceId      String    @map("workspace_id")
  name             String
  frequency        String
  recipientEmails  String[]  @map("recipient_emails")
  body             Json
  enabled          Boolean   @default(true)
  nextRunAt        DateTime  @map("next_run_at")
  lastRunAt        DateTime? @map("last_run_at")
  lastRunStatus    String?   @map("last_run_status")
  lastRunError     String?   @map("last_run_error")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  workspace        Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([nextRunAt, enabled])
  @@map("export_schedules")
}

model ExportJob {
  id                String    @id @default(uuid())
  workspaceId       String    @map("workspace_id")
  requestedByUserId String    @map("requested_by_user_id")
  body              Json
  status            String
  filename          String?
  contentType       String?   @map("content_type")
  byteSize          Int?      @map("byte_size")
  storageKey        String?   @map("storage_key")
  errorMessage      String?   @map("error_message")
  createdAt         DateTime  @default(now()) @map("created_at")
  completedAt       DateTime? @map("completed_at")
  expiresAt         DateTime? @map("expires_at")
  workspace         Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  requestedBy       User      @relation(fields: [requestedByUserId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt(sort: Desc)])
  @@index([status, createdAt])
  @@map("export_jobs")
}

model ReportShare {
  id          String    @id @default(uuid())
  workspaceId String    @map("workspace_id")
  token       String    @unique
  body        Json
  expiresAt   DateTime  @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@map("report_shares")
}

model WidgetShare {
  id          String    @id @default(uuid())
  workspaceId String    @map("workspace_id")
  token       String    @unique
  body        Json
  expiresAt   DateTime  @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@map("widget_shares")
}

/// Persisted refresh tokens — enables server-side revocation and rotation.
/// A token is "valid" if revokedAt IS NULL and expiresAt > NOW().
model RefreshToken {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  workspaceId String    @map("workspace_id")
  tokenHash   String    @unique @map("token_hash")  // SHA-256 of the raw JWT
  family      String    // Random family ID — rotating every refresh; used for replay detection
  userAgent   String?   @map("user_agent")
  ipAddress   String?   @map("ip_address")
  lastUsedAt  DateTime? @map("last_used_at")
  revokedAt   DateTime? @map("revoked_at")
  expiresAt   DateTime  @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@index([userId, family, revokedAt, expiresAt])
  @@map("refresh_tokens")
}

/// Represents a timesheet approval period for a user on a project.
/// States: DRAFT → SUBMITTED → APPROVED | REJECTED → SUBMITTED …
enum TimesheetStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  WAIVED
}

enum AmendmentStatus {
  PENDING
  APPROVED
  DENIED
}

model TimesheetPeriod {
  id          String          @id @default(uuid())
  userId      String          @map("user_id")
  workspaceId String          @map("workspace_id")
  projectId   String          @map("project_id")
  periodStart    DateTime        @map("period_start")
  periodEnd      DateTime        @map("period_end")
  approvalPeriod String?         @map("approval_period")
  status         TimesheetStatus @default(DRAFT)
  note        String?
  reviewNote  String?         @map("review_note")
  reviewedBy  String?         @map("reviewed_by")
  submittedAt DateTime?       @map("submitted_at")
  reviewedAt  DateTime?       @map("reviewed_at")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  project     Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  amendments  TimesheetAmendmentRequest[]

  @@unique([userId, projectId, periodStart])
  @@index([workspaceId, status])
  @@index([periodStart])
  @@index([projectId])
  @@map("timesheet_periods")
}

model TimesheetAmendmentRequest {
  id          String          @id @default(uuid())
  periodId    String          @map("period_id")
  userId      String          @map("user_id")
  workspaceId String          @map("workspace_id")
  reason      String
  status      AmendmentStatus @default(PENDING)
  adminNote   String?         @map("admin_note")
  reviewedBy  String?         @map("reviewed_by")
  reviewedAt  DateTime?       @map("reviewed_at")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  period      TimesheetPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([workspaceId, status])
  @@index([periodId, status])
  // Partial unique index: amendment_one_pending_per_period (period_id) WHERE status = 'PENDING'
  // Defined in migration 20260615173546_add_amendment_pending_unique_index — not expressible in Prisma 6 schema.
  @@map("timesheet_amendment_requests")
}

/// Audit trail for all TimeLog mutations.
/// IMPORTANT: timeLogId is intentionally NOT a FK (no @relation).
/// Audit records are preserved indefinitely even if the source TimeLog is deleted.
/// This is by design for compliance and dispute resolution purposes.
/// Do NOT add onDelete cascade to this field.
model TimeLogAuditEvent {
  id          String   @default(uuid())
  workspaceId String   @map("workspace_id")
  timeLogId   String   @map("time_log_id")
  entryUserId String   @map("entry_user_id")
  actorId     String   @map("actor_id")
  action      String
  before      Json?
  after       Json?
  createdAt   DateTime @default(now()) @map("created_at")

  @@id([id, createdAt])
  @@index([timeLogId, createdAt])
  @@index([workspaceId, createdAt])
  @@index([workspaceId, entryUserId, createdAt(sort: Desc)])
  @@map("time_log_audit_events")
}

/// API key + secret pairs for third-party read-only reporting access (Postman / integrations).
model ReportingApiCredential {
  id          String    @id @default(uuid())
  workspaceId String    @map("workspace_id")
  name        String
  apiKey      String    @unique @map("api_key")
  secretHash  String    @map("secret_hash")
  projectIds  String[]  @map("project_ids")
  isActive    Boolean   @default(true) @map("is_active")
  lastUsedAt  DateTime? @map("last_used_at")
  expiresAt   DateTime? @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@map("reporting_api_credentials")
}
