generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

generator seed_client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
  output        = "./generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String            @id @default(uuid())
  email                 String            @unique
  passwordHash          String            @map("password_hash")
  name                  String
  firstName             String?           @map("first_name")
  lastName              String?           @map("last_name")
  phone                 String?
  location              String?
  avatarUrl             String?           @map("avatar_url")
  jobTitle              String?           @map("job_title")
  department            String?
  workStartDate         DateTime?         @map("work_start_date") @db.Date
  totpSecret            String?           @map("totp_secret")
  totpEnabledAt         DateTime?         @map("totp_enabled_at")
  mustChangePassword    Boolean           @default(false) @map("must_change_password")
  emailVerifiedAt       DateTime?         @map("email_verified_at")
  emailVerificationTokenHash String?      @map("email_verification_token_hash")
  emailVerificationExpiresAt DateTime?     @map("email_verification_expires_at")
  phoneVerifiedAt            DateTime?     @map("phone_verified_at")
  phoneVerificationCodeHash  String?       @map("phone_verification_code_hash")
  phoneVerificationExpiresAt DateTime?     @map("phone_verification_expires_at")
  pendingPhone               String?       @map("pending_phone")
  passwordResetTokenHash String?          @map("password_reset_token_hash")
  passwordResetExpiresAt DateTime?        @map("password_reset_expires_at")
  defaultHourlyRate     Decimal?          @map("default_hourly_rate") @db.Decimal(10, 2)
  preferences           Json              @default("{}")
  createdAt             DateTime          @default(now()) @map("created_at")
  updatedAt             DateTime          @updatedAt @map("updated_at")
  memberships           WorkspaceMember[]
  timeLogs              TimeLog[]
  hourlyRates           HourlyRate[]
  teamMembers           TeamMember[]
  projectInvitesCreated ProjectInvite[]   @relation("ProjectInvitesCreated")
  refreshTokens         RefreshToken[]
  timesheetPeriods      TimesheetPeriod[]
  timesheetAmendments   TimesheetAmendmentRequest[]
  taskAssignees         TaskAssignee[]
  projectColors         UserProjectColor[]
  notifications         Notification[]
  exportJobs            ExportJob[]
  tenantDataExportJobs  TenantDataExportJob[]
  salesInquiriesRequested TenantSalesInquiry[]
  salesInquiryReceiptsUploaded TenantSalesInquiryReceipt[]
  jiraEmail             String?           @map("jira_email")
  tenantMembership      TenantMember?

  @@map("users")
}

model Tenant {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  status    String   @default("pending_setup")
  settings  Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  members      TenantMember[]
  workspaces   Workspace[]
  subscription TenantSubscription?
  auditEvents  PlatformAuditEvent[]
  dataExportJobs TenantDataExportJob[]
  salesInquiries TenantSalesInquiry[]
  subscriptionEvents TenantSubscriptionEvent[]
  helpDeskTickets    HelpDeskTicket[]
  churnedAt    DateTime? @map("churned_at")

  @@map("tenants")
}

model Plan {
  id              String   @id @default(uuid())
  name            String
  slug            String   @unique
  limits          Json
  isPublic        Boolean  @default(false) @map("is_public")
  sortOrder       Int      @default(0) @map("sort_order")
  stripeProductId String?  @unique @map("stripe_product_id")
  stripePriceId     String?  @unique @map("stripe_price_id")
  tagline           String?
  monthlyPriceCents Int?     @map("monthly_price_cents")
  yearlyPriceCents  Int?     @map("yearly_price_cents")
  features          Json?
  recommended       Boolean  @default(false)
  billingMode       String   @default("stripe") @map("billing_mode")
  contactHref       String?  @map("contact_href")
  visibleOnPricing  Boolean  @default(false) @map("visible_on_pricing")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  subscriptions TenantSubscription[]
  salesInquiries TenantSalesInquiry[]

  @@map("plans")
}

model PlatformCatalogSettings {
  id                      Int      @id @default(1)
  pricingBaselineFeatures Json     @default("[]") @map("pricing_baseline_features")
  updatedAt               DateTime @updatedAt @map("updated_at")

  @@map("platform_catalog_settings")
}

model TenantSubscription {
  id                   String    @id @default(uuid())
  tenantId             String    @unique @map("tenant_id")
  planId               String    @map("plan_id")
  status               String
  trialEndsAt          DateTime? @map("trial_ends_at")
  currentPeriodEnd     DateTime? @map("current_period_end")
  limitsOverride       Json?     @map("limits_override")
  stripeCustomerId     String?   @unique @map("stripe_customer_id")
  stripeSubscriptionId String?   @unique @map("stripe_subscription_id")
  currentPeriodStart   DateTime? @map("current_period_start")
  billingInterval      String?   @map("billing_interval")
  planAssignedAt       DateTime  @default(now()) @map("plan_assigned_at")
  billingSource        String    @default("manual") @map("billing_source")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan   Plan   @relation(fields: [planId], references: [id])
  events TenantSubscriptionEvent[]

  @@index([planId])
  @@map("tenant_subscriptions")
}

model TenantSubscriptionEvent {
  id             String    @id @default(uuid())
  tenantId       String    @map("tenant_id")
  subscriptionId String    @map("subscription_id")
  eventType      String    @map("event_type")
  occurredAt     DateTime  @map("occurred_at")
  fromPlanId     String?   @map("from_plan_id")
  toPlanId       String?   @map("to_plan_id")
  fromStatus     String?   @map("from_status")
  toStatus       String?   @map("to_status")
  actorType      String    @map("actor_type") // 'system' | 'platform_user' | 'tenant_owner'
  actorId        String?   @map("actor_id")
  metadata       Json?     @map("metadata")
  createdAt      DateTime  @default(now()) @map("created_at")

  tenant       Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subscription TenantSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([tenantId, occurredAt(sort: Desc)])
  @@index([eventType, occurredAt])
  @@map("tenant_subscription_events")
}

model StripeWebhookEvent {
  id          String   @id
  type        String
  processedAt DateTime @default(now()) @map("processed_at")

  @@map("stripe_webhook_events")
}

model TenantSalesInquiry {
  id                 String    @id @default(uuid())
  tenantId           String    @map("tenant_id")
  requestedPlanId    String    @map("requested_plan_id")
  requestedByUserId  String    @map("requested_by_user_id")
  message            String?
  billingInterval    String?   @map("billing_interval")
  status             String    @default("open")
  instructionsSentAt DateTime? @map("instructions_sent_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  fulfilledAt        DateTime? @map("fulfilled_at")

  tenant        Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  requestedPlan Plan                       @relation(fields: [requestedPlanId], references: [id])
  requestedBy   User                       @relation(fields: [requestedByUserId], references: [id])
  receipts      TenantSalesInquiryReceipt[]

  @@index([tenantId, status])
  @@map("tenant_sales_inquiries")
}

model TenantSalesInquiryReceipt {
  id               String   @id @default(uuid())
  inquiryId        String   @map("inquiry_id")
  uploadedByUserId String   @map("uploaded_by_user_id")
  filename         String
  contentType      String   @map("content_type")
  storageKey       String   @map("storage_key")
  sizeBytes        Int      @map("size_bytes")
  createdAt        DateTime @default(now()) @map("created_at")

  inquiry    TenantSalesInquiry @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  uploadedBy User               @relation(fields: [uploadedByUserId], references: [id])

  @@index([inquiryId])
  @@map("tenant_sales_inquiry_receipts")
}

model PlatformUser {
  id                     String                 @id @default(uuid())
  email                  String                 @unique
  passwordHash           String                 @map("password_hash")
  name                   String
  role                   String                 @default("SUPERADMIN")
  preferences            Json                   @default("{}")
  isActive               Boolean                @default(true) @map("is_active")
  totpSecret             String?                @map("totp_secret")
  totpEnabledAt          DateTime?              @map("totp_enabled_at")
  passwordResetTokenHash String?                @map("password_reset_token_hash")
  passwordResetExpiresAt DateTime?              @map("password_reset_expires_at")
  createdAt              DateTime               @default(now()) @map("created_at")
  updatedAt              DateTime               @updatedAt @map("updated_at")
  refreshTokens PlatformRefreshToken[]
  auditEvents   PlatformAuditEvent[]
  notifications PlatformNotification[]
  ticketsAssigned HelpDeskTicket[] @relation("TicketsAssigned")
  helpDeskAgentEntries HelpDeskAgent[]
  helpDeskMessages HelpDeskTicketMessage[]

  @@map("platform_users")
}

model PlatformRefreshToken {
  id             String       @id @default(uuid())
  platformUserId String       @map("platform_user_id")
  tokenHash      String       @unique @map("token_hash")
  family         String
  userAgent      String?      @map("user_agent")
  ipAddress      String?      @map("ip_address")
  lastUsedAt     DateTime?    @map("last_used_at")
  revokedAt      DateTime?    @map("revoked_at")
  expiresAt      DateTime     @map("expires_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  platformUser   PlatformUser @relation(fields: [platformUserId], references: [id], onDelete: Cascade)

  @@index([platformUserId])
  @@index([platformUserId, family, revokedAt, expiresAt])
  @@map("platform_refresh_tokens")
}

model PlatformNotification {
  id             String       @id @default(uuid())
  platformUserId String       @map("platform_user_id")
  type           String
  title          String
  body           String
  metadata       Json         @default("{}")
  readAt         DateTime?    @map("read_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  platformUser   PlatformUser @relation(fields: [platformUserId], references: [id], onDelete: Cascade)

  @@index([platformUserId, createdAt(sort: Desc)])
  @@index([platformUserId, readAt])
  @@map("platform_notifications")
}

model PlatformAuditEvent {
  id                  String   @id @default(uuid())
  actorPlatformUserId String   @map("actor_platform_user_id")
  action              String
  tenantId            String?  @map("tenant_id")
  summary             Json
  ipAddress           String?  @map("ip_address")
  userAgent           String?  @map("user_agent")
  createdAt           DateTime @default(now()) @map("created_at")

  actor  PlatformUser @relation(fields: [actorPlatformUserId], references: [id])
  tenant Tenant?      @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([createdAt(sort: Desc)])
  @@index([tenantId, createdAt(sort: Desc)])
  @@index([actorPlatformUserId, createdAt(sort: Desc)])
  @@map("platform_audit_events")
}

model TenantMember {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  userId    String   @unique @map("user_id")
  role      String
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("tenant_members")
}

model Workspace {
  id              String            @id @default(uuid())
  tenantId        String            @map("tenant_id")
  name            String
  slug            String            @unique
  settings        Json              @default("{}")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  tenant          Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  members         WorkspaceMember[]
  projects        Project[]
  categories      Category[]
  hourlyRates     HourlyRate[]
  exportPresets   ExportPreset[]
  exportSchedules ExportSchedule[]
  exportJobs      ExportJob[]
  reportShares    ReportShare[]
  reportingApiCredentials ReportingApiCredential[]
  widgetShares    WidgetShare[]
  notifications   Notification[]

  @@index([tenantId])
  @@map("workspaces")
}

model Notification {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  workspaceId String    @map("workspace_id")
  type        String
  title       String
  body        String
  metadata    Json      @default("{}")
  readAt      DateTime? @map("read_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([userId, workspaceId, createdAt(sort: Desc)])
  @@index([userId, workspaceId, readAt])
  @@index([metadata], type: Gin)
  @@map("notifications")
}

/// Workspace-scoped category that groups tasks (e.g. "Software Development",
/// "UI/UX Design", "Meetings"). Managed by Admin only.
model Category {
  id          String    @id @default(uuid())
  workspaceId String    @map("workspace_id")
  name        String
  description String?
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tasks       Task[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
  @@index([workspaceId, isActive])
  @@map("categories")
}

model WorkspaceMember {
  id          String    @id @default(uuid())
  workspaceId String    @map("workspace_id")
  userId      String    @map("user_id")
  role        String
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@map("workspace_members")
}

model Project {
  id                       String            @id @default(uuid())
  workspaceId              String            @map("workspace_id")
  name                     String
  color                    String            @default("#6366f1")
  clientName               String?           @map("client_name")
  budgetHours              Decimal?          @map("budget_hours") @db.Decimal(10, 2)
  isActive                 Boolean           @default(true) @map("is_active")
  timesheetApprovalEnabled             Boolean           @default(false) @map("timesheet_approval_enabled")
  timesheetApprovalPeriod              String?           @map("timesheet_approval_period")
  timesheetApprovalEnabledAt           DateTime?         @map("timesheet_approval_enabled_at")
  timesheetApprovalPeriodEffectiveAt   DateTime?         @map("timesheet_approval_period_effective_at")
  createdAt                            DateTime          @default(now()) @map("created_at")
  updatedAt                DateTime          @updatedAt @map("updated_at")
  workspace                Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  team                     Team?
  tasks                    Task[]
  hourlyRates              HourlyRate[]
  invites                  ProjectInvite[]
  timesheetPeriods         TimesheetPeriod[]
  userColors               UserProjectColor[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
  @@map("projects")
}

/// Each project has exactly one team of members who may log time on it.
model Team {
  id        String       @id @default(uuid())
  projectId String       @unique @map("project_id")
  createdAt DateTime     @default(now()) @map("created_at")
  project   Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  members   TeamMember[]

  @@map("teams")
}

model TeamMember {
  id        String   @id @default(uuid())
  teamId    String   @map("team_id")
  userId    String   @map("user_id")
  role      String   @default("MEMBER")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([userId])
  @@map("team_members")
}

model ProjectInvite {
  id          String    @id @default(uuid())
  projectId   String    @map("project_id")
  token       String    @unique
  email       String?
  expiresAt   DateTime  @map("expires_at")
  acceptedAt  DateTime? @map("accepted_at")
  createdById String    @map("created_by_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy   User      @relation("ProjectInvitesCreated", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([email])
  @@map("project_invites")
}

model Task {
  id              String    @id @default(uuid())
  projectId       String    @map("project_id")
  categoryId      String    @map("category_id")
  taskName        String    @map("task_name")
  billableDefault Boolean   @default(true) @map("billable_default")
  isCommon        Boolean   @default(true) @map("is_common")
  isActive        Boolean   @default(true) @map("is_active")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  project         Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  category        Category  @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  timeLogs        TimeLog[]
  assignees       TaskAssignee[]

  @@index([projectId])
  @@index([categoryId])
  @@index([projectId, isActive])
  @@map("tasks")
}

model TaskAssignee {
  id        String   @id @default(uuid())
  taskId    String   @map("task_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
  @@index([userId])
  @@map("task_assignees")
}

model UserProjectColor {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  projectId String   @map("project_id")
  color     String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@map("user_project_colors")
}

model TimeLog {
  id          String   @default(uuid())
  userId      String   @map("user_id")
  taskId      String   @map("task_id")
  startTime   DateTime @map("start_time")
  endTime     DateTime @map("end_time")
  durationSec Int      @map("duration_sec")
  description String?
  isBillable  Boolean  @default(true) @map("is_billable")
  source      String
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@id([id, startTime])
  @@index([userId, startTime])
  @@index([taskId, startTime])
  @@index([startTime])
  @@map("time_logs")
}

model HourlyRate {
  id            String    @id @default(uuid())
  workspaceId   String    @map("workspace_id")
  userId        String?   @map("user_id")
  projectId     String?   @map("project_id")
  rate          Decimal   @db.Decimal(10, 2)
  effectiveFrom DateTime  @map("effective_from")
  createdAt     DateTime  @default(now()) @map("created_at")
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user          User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project       Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([workspaceId, effectiveFrom])
  @@unique([workspaceId, userId, projectId, effectiveFrom])
  @@map("hourly_rates")
}

model ExportPreset {
  id          String    @id @default(uuid())
  workspaceId String    @map("workspace_id")
  name        String
  body        Json
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, name])
  @@index([workspaceId])
  @@map("export_presets")
}

model ExportSchedule {
  id               String    @id @default(uuid())
  workspaceId      String    @map("workspace_id")
  name             String
  frequency        String
  recipientEmails  String[]  @map("recipient_emails")
  body             Json
  enabled          Boolean   @default(true)
  nextRunAt        DateTime  @map("next_run_at")
  lastRunAt        DateTime? @map("last_run_at")
  lastRunStatus    String?   @map("last_run_status")
  lastRunError     String?   @map("last_run_error")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  workspace        Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([nextRunAt, enabled])
  @@map("export_schedules")
}

model ExportJob {
  id                String    @id @default(uuid())
  workspaceId       String    @map("workspace_id")
  requestedByUserId String    @map("requested_by_user_id")
  body              Json
  status            String
  filename          String?
  contentType       String?   @map("content_type")
  byteSize          Int?      @map("byte_size")
  storageKey        String?   @map("storage_key")
  errorMessage      String?   @map("error_message")
  createdAt         DateTime  @default(now()) @map("created_at")
  completedAt       DateTime? @map("completed_at")
  expiresAt         DateTime? @map("expires_at")
  workspace         Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  requestedBy       User      @relation(fields: [requestedByUserId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt(sort: Desc)])
  @@index([status, createdAt])
  @@map("export_jobs")
}

model TenantDataExportJob {
  id                String    @id @default(uuid())
  tenantId          String    @map("tenant_id")
  requestedByUserId String    @map("requested_by_user_id")
  status            String
  filename          String?
  contentType       String?   @map("content_type")
  byteSize          Int?      @map("byte_size")
  storageKey        String?   @map("storage_key")
  errorMessage      String?   @map("error_message")
  createdAt         DateTime  @default(now()) @map("created_at")
  completedAt       DateTime? @map("completed_at")
  expiresAt         DateTime? @map("expires_at")
  tenant            Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  requestedBy       User      @relation(fields: [requestedByUserId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt(sort: Desc)])
  @@index([status, createdAt])
  @@map("tenant_data_export_jobs")
}

model ReportShare {
  id          String    @id @default(uuid())
  workspaceId String    @map("workspace_id")
  token       String    @unique
  body        Json
  expiresAt   DateTime  @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@map("report_shares")
}

model WidgetShare {
  id          String    @id @default(uuid())
  workspaceId String    @map("workspace_id")
  token       String    @unique
  body        Json
  expiresAt   DateTime  @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@map("widget_shares")
}

/// Persisted refresh tokens — enables server-side revocation and rotation.
/// A token is "valid" if revokedAt IS NULL and expiresAt > NOW().
model RefreshToken {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  workspaceId String    @map("workspace_id")
  tokenHash   String    @unique @map("token_hash")  // SHA-256 of the raw JWT
  family      String    // Random family ID — rotating every refresh; used for replay detection
  userAgent   String?   @map("user_agent")
  ipAddress   String?   @map("ip_address")
  lastUsedAt  DateTime? @map("last_used_at")
  revokedAt   DateTime? @map("revoked_at")
  expiresAt   DateTime  @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@index([userId, family, revokedAt, expiresAt])
  @@map("refresh_tokens")
}

/// Represents a timesheet approval period for a user on a project.
/// States: DRAFT → SUBMITTED → APPROVED | REJECTED → SUBMITTED …
enum TimesheetStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  WAIVED
}

enum AmendmentStatus {
  PENDING
  APPROVED
  DENIED
}

model TimesheetPeriod {
  id          String          @id @default(uuid())
  userId      String          @map("user_id")
  workspaceId String          @map("workspace_id")
  projectId   String          @map("project_id")
  periodStart    DateTime        @map("period_start")
  periodEnd      DateTime        @map("period_end")
  approvalPeriod String?         @map("approval_period")
  status         TimesheetStatus @default(DRAFT)
  note        String?
  reviewNote  String?         @map("review_note")
  reviewedBy  String?         @map("reviewed_by")
  submittedAt DateTime?       @map("submitted_at")
  reviewedAt  DateTime?       @map("reviewed_at")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  project     Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  amendments  TimesheetAmendmentRequest[]

  @@unique([userId, projectId, periodStart])
  @@index([workspaceId, status])
  @@index([periodStart])
  @@index([projectId])
  @@map("timesheet_periods")
}

model TimesheetAmendmentRequest {
  id          String          @id @default(uuid())
  periodId    String          @map("period_id")
  userId      String          @map("user_id")
  workspaceId String          @map("workspace_id")
  reason      String
  status      AmendmentStatus @default(PENDING)
  adminNote   String?         @map("admin_note")
  reviewedBy  String?         @map("reviewed_by")
  reviewedAt  DateTime?       @map("reviewed_at")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  period      TimesheetPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([workspaceId, status])
  @@index([periodId, status])
  // Partial unique index: amendment_one_pending_per_period (period_id) WHERE status = 'PENDING'
  // Defined in migration 20260615173546_add_amendment_pending_unique_index — not expressible in Prisma 6 schema.
  @@map("timesheet_amendment_requests")
}

/// Audit trail for all TimeLog mutations.
/// IMPORTANT: timeLogId is intentionally NOT a FK (no @relation).
/// Audit records are preserved indefinitely even if the source TimeLog is deleted.
/// This is by design for compliance and dispute resolution purposes.
/// Do NOT add onDelete cascade to this field.
model TimeLogAuditEvent {
  id          String   @default(uuid())
  workspaceId String   @map("workspace_id")
  timeLogId   String   @map("time_log_id")
  entryUserId String   @map("entry_user_id")
  actorId     String   @map("actor_id")
  action      String
  before      Json?
  after       Json?
  createdAt   DateTime @default(now()) @map("created_at")

  @@id([id, createdAt])
  @@index([timeLogId, createdAt])
  @@index([workspaceId, createdAt])
  @@index([workspaceId, entryUserId, createdAt(sort: Desc)])
  @@map("time_log_audit_events")
}

/// API key + secret pairs for third-party read-only reporting access (Postman / integrations).
model ReportingApiCredential {
  id          String    @id @default(uuid())
  workspaceId String    @map("workspace_id")
  name        String
  apiKey      String    @unique @map("api_key")
  secretHash  String    @map("secret_hash")
  projectIds  String[]  @map("project_ids")
  isActive    Boolean   @default(true) @map("is_active")
  lastUsedAt  DateTime? @map("last_used_at")
  expiresAt   DateTime? @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@map("reporting_api_credentials")
}

enum TicketStatus {
  OPEN
  PENDING
  IN_PROGRESS
  ON_HOLD
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TicketChannel {
  WEB_FORM
  EMAIL
  PLATFORM_ADMIN
  API
}

enum TicketType {
  BUG_REPORT
  BILLING
  PLAN_QUESTION
  FEATURE_REQUEST
  IN_APP_REPORT
  SECURITY
  GENERAL

  @@map("ticket_type")
}

enum MessageDirection {
  INBOUND
  OUTBOUND
  INTERNAL
}

model HelpDeskQueue {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  description String?
  color       String   @default("#6366f1")
  isActive    Boolean  @default(true)  @map("is_active")
  sortOrder   Int      @default(0)     @map("sort_order")
  slaPolicy   Json?    @map("sla_policy")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt      @map("updated_at")

  tickets     HelpDeskTicket[]
  agents      HelpDeskAgent[]

  @@map("helpdesk_queues")
}

model HelpDeskAgent {
  id        String        @id @default(uuid())
  queueId   String        @map("queue_id")
  platformUserId String   @map("platform_user_id")
  isActive  Boolean       @default(true) @map("is_active")
  createdAt DateTime      @default(now()) @map("created_at")

  queue        HelpDeskQueue @relation(fields: [queueId], references: [id], onDelete: Cascade)
  platformUser PlatformUser  @relation(fields: [platformUserId], references: [id], onDelete: Cascade)

  @@unique([queueId, platformUserId])
  @@index([platformUserId])
  @@map("helpdesk_agents")
}

model HelpDeskTicket {
  id              String          @id @default(uuid())
  ticketNumber    Int             @unique @default(autoincrement()) @map("ticket_number")
  queueId         String          @map("queue_id")
  status          TicketStatus    @default(OPEN)
  priority        TicketPriority  @default(MEDIUM)
  ticketType      TicketType      @default(GENERAL) @map("ticket_type")
  channel         TicketChannel   @default(WEB_FORM)
  subject         String
  requesterName   String          @map("requester_name")
  requesterEmail  String          @map("requester_email")
  tenantId        String?         @map("tenant_id")
  assignedToId    String?         @map("assigned_to_id")
  tags            Json            @default("[]")
  metadata        Json?           // type-specific dynamic fields
  firstResponseAt DateTime?       @map("first_response_at")
  resolvedAt      DateTime?       @map("resolved_at")
  closedAt        DateTime?       @map("closed_at")
  slaBreached     Boolean         @default(false) @map("sla_breached")
  firstResponseDue DateTime?      @map("first_response_due")
  resolutionDue   DateTime?       @map("resolution_due")
  internalNote    String?         @map("internal_note")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt      @map("updated_at")

  queue           HelpDeskQueue   @relation(fields: [queueId], references: [id])
  assignedTo      PlatformUser?   @relation("TicketsAssigned", fields: [assignedToId], references: [id])
  tenant          Tenant?         @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  messages        HelpDeskTicketMessage[]
  history         HelpDeskTicketHistory[]

  @@index([queueId, status])
  @@index([assignedToId, status])
  @@index([tenantId])
  @@index([status, createdAt(sort: Desc)])
  @@index([requesterEmail])
  @@index([slaBreached, status])
  @@map("helpdesk_tickets")
}

model HelpDeskTicketMessage {
  id          String           @id @default(uuid())
  ticketId    String           @map("ticket_id")
  direction   MessageDirection
  authorId    String?          @map("author_id")
  authorName  String           @map("author_name")
  authorEmail String           @map("author_email")
  body        String
  htmlBody    String?          @map("html_body")
  emailMessageId String?       @unique @map("email_message_id")
  attachments Json             @default("[]")
  createdAt   DateTime         @default(now()) @map("created_at")

  ticket  HelpDeskTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author  PlatformUser?  @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([ticketId, createdAt])
  @@map("helpdesk_ticket_messages")
}

model HelpDeskTicketHistory {
  id          String   @id @default(uuid())
  ticketId    String   @map("ticket_id")
  actorId     String?  @map("actor_id")
  actorName   String   @map("actor_name")
  action      String
  before      Json?
  after       Json?
  createdAt   DateTime @default(now()) @map("created_at")

  ticket HelpDeskTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId, createdAt(sort: Desc)])
  @@map("helpdesk_ticket_history")
}
