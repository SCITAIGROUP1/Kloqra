# Postgres.app / local Postgres (no Docker):
DATABASE_URL=postgresql://kloqra:kloqra@localhost:5432/kloqra
REDIS_URL=redis://localhost:6379

# Or Docker: postgresql://kloqra:kloqra@localhost:5432/kloqra
# REDIS_USE_MEMORY=true
# Or Docker Redis: REDIS_URL=redis://localhost:6379
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
FRONTEND_ORIGIN=http://localhost:3000,http://localhost:3002
PUBLIC_ADMIN_URL=http://localhost:3002
# Cross-site prod (Vercel + Railway): AUTH_COOKIE_SAME_SITE=none (auto-detected if omitted)
# AUTH_COOKIE_SAME_SITE=lax
# AUTH_COOKIE_SECURE=true
# REFRESH_ROTATION_GRACE_MS=10000
# COOKIE_DOMAIN=.kloqra.dev # Only for same-registrable-domain subdomains; omit for Vercel+Railway
PORT=3001

# Timer hard auto-stop ceiling (hours). Client NEXT_PUBLIC_HARD_AUTO_STOP_HOURS should match.
HARD_AUTO_STOP_HOURS=12

# Member help assistant (optional — without these, /assistant/chat returns static fallback)
# ASSISTANT_SERVICE_URL=http://localhost:3003
# ASSISTANT_INTERNAL_SECRET=change-me-assistant-secret
# ASSISTANT_ENABLED=true

# Brevo / email (member provisioning). Required on Railway/production.
# Without these, invites succeed but no welcome email is sent. Omit locally — temp passwords log to API console.
#
# Railway Hobby blocks outbound SMTP (ports 587/465). On Railway, Brevo HTTPS API is used automatically
# when SMTP_HOST is Brevo and SMTP_PASS is set. Local dev can use SMTP directly.
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_USER=your-brevo-smtp-login
# SMTP_PASS=your-brevo-smtp-key   # xsmtpsib-… — local SMTP only
# SMTP_FROM=Kloqra <noreply@yourdomain.com>
# BREVO_API_KEY=your-brevo-api-key   # xkeysib-… — required on Railway (HTTP API)
# EMAIL_TRANSPORT=brevo_api          # optional: force HTTPS API
# PUBLIC_CLIENT_URL=https://chrono-mint-client.vercel.app
