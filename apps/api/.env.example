# Postgres.app / local Postgres (no Docker):
DATABASE_URL=postgresql://chronomint:chronomint@localhost:5432/chronomint
REDIS_URL=redis://localhost:6379

# Or Docker: postgresql://chronomint:chronomint@localhost:5432/chronomint
# REDIS_USE_MEMORY=true
# Or Docker Redis: REDIS_URL=redis://localhost:6379
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
FRONTEND_ORIGIN=http://localhost:3000,http://localhost:3002
PUBLIC_ADMIN_URL=http://localhost:3002
# COOKIE_DOMAIN=.chronomint.dev # Set in production to share cookies across subdomains
PORT=3001
