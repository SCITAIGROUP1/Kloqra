# Postgres.app / local Postgres (no Docker):
DATABASE_URL=postgresql://kloqra:kloqra@localhost:5432/kloqra

# Seed: `minimal` = plans + platform superadmin only; `demo` = full demo org (CI/e2e default)
# SEED_MODE=minimal
REDIS_URL=redis://localhost:6379

# Or Docker: postgresql://kloqra:kloqra@localhost:5432/kloqra
# REDIS_USE_MEMORY=true
# Or Docker Redis: REDIS_URL=redis://localhost:6379
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
PUBLIC_CLIENT_URL=http://localhost:3000
PUBLIC_ADMIN_URL=http://localhost:3002
PUBLIC_PLATFORM_URL=http://localhost:3003
# Self-serve signup (SaaS-F20). Keep false until legal sign-off (F23).
# SELF_SERVE_SIGNUP_ENABLED=true
# Hard delete retention after churn (SaaS-F23). Default 30 days.
# TENANT_DELETE_MIN_DAYS_AFTER_CHURN=30
# Cross-site prod (Vercel + Railway): AUTH_COOKIE_SAME_SITE=none (auto-detected if omitted)
# AUTH_COOKIE_SAME_SITE=lax
# AUTH_COOKIE_SECURE=true
# REFRESH_ROTATION_GRACE_MS=10000
# COOKIE_DOMAIN=.kloqra.dev # Only for same-registrable-domain subdomains; omit for Vercel+Railway
PORT=3001

# Timer hard auto-stop ceiling (hours). Client NEXT_PUBLIC_HARD_AUTO_STOP_HOURS should match.
HARD_AUTO_STOP_HOURS=12

# Member help assistant (optional — without these, /assistant/chat returns static fallback)
# ASSISTANT_SERVICE_URL=http://localhost:3003
# ASSISTANT_INTERNAL_SECRET=change-me-assistant-secret
# ASSISTANT_ENABLED=true

# Client commercial features (rates, revenue amounts, invoices, project hour budgets).
# Default ON. Set false for UAT to hide/reject without deleting code. Does not affect SaaS /account/billing or isBillable.
# CLIENT_COMMERCIAL_FEATURES_ENABLED=false

# Brevo / email (member provisioning). Required on Railway/production.
# Without these, invites succeed but no welcome email is sent. Omit locally — temp passwords log to API console.
#
# Railway Hobby blocks outbound SMTP (ports 587/465). On Railway, Brevo HTTPS API is used automatically
# when SMTP_HOST is Brevo and SMTP_PASS is set. Local dev can use SMTP directly.
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_USER=your-brevo-smtp-login
# SMTP_PASS=your-brevo-smtp-key   # xsmtpsib-… — local SMTP only
# SMTP_FROM=Kloqra <noreply@yourdomain.com>
# BREVO_API_KEY=your-brevo-api-key   # xkeysib-… — required on Railway (HTTP API)
# EMAIL_TRANSPORT=brevo_api          # optional: force HTTPS API

# Platform superadmin seed (SaaS-F14) — used by prisma seed for apps/platform-admin
# PLATFORM_SUPERADMIN_EMAIL=platform@kloqra.dev
# PLATFORM_SUPERADMIN_PASSWORD=password123
# Create test Products/Prices in Stripe Dashboard, then paste keys below.
# Local webhooks: stripe listen --forward-to localhost:3001/webhooks/stripe
# Omit STRIPE_SECRET_KEY until you enable BILLING_STRIPE_CHECKOUT=true for real Checkout.
# BILLING_STRIPE_CHECKOUT=true
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# Plan catalog (SaaS-F09/F11) — overrides seed ids (defaults: price_test_starter / price_test_pro)
# STRIPE_PRICE_STARTER=price_test_starter
# STRIPE_PRICE_PRO=price_test_pro
# STRIPE_PRODUCT_STARTER=prod_test_starter
# STRIPE_PRODUCT_PRO=prod_test_pro
# Contact sales (Enterprise manual billing)
# BILLING_MANUAL_PAYMENT_INSTRUCTIONS=Wire transfer to …
# BILLING_RECEIPTS_DIR=.billing-receipts
