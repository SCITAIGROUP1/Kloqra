# Staging environment — copy values into Railway / Vercel dashboards.
# Generate secrets: bash scripts/deploy/generate-secrets.sh
# Full guide: docs/runbooks/railway.md

# --- Railway API service (kloqra-staging) ---
DATABASE_URL=${{Postgres.DATABASE_URL}}
REDIS_URL=<from Railway Redis plugin>
JWT_ACCESS_SECRET=<unique-32+-chars>
JWT_REFRESH_SECRET=<unique-32+-chars>
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
PUBLIC_CLIENT_URL=https://kloqra-client-staging.vercel.app
PUBLIC_ADMIN_URL=https://kloqra-admin-staging.vercel.app
PUBLIC_PLATFORM_URL=https://kloqra-platform-staging.vercel.app
AUTH_COOKIE_SAME_SITE=none
AUTH_COOKIE_SECURE=true
REFRESH_ROTATION_GRACE_MS=10000
HARD_AUTO_STOP_HOURS=12
NODE_ENV=production
# Client commercial (rates/revenue/budgets/invoices). false = UAT hide/reject; true/omit = on.
# Does not affect SaaS /account/billing or isBillable.
CLIENT_COMMERCIAL_FEATURES_ENABLED=false
# Do not set PORT — Railway injects it.

# Email (required for member invite / password emails). Brevo example:
# Railway Hobby blocks outbound SMTP — API HTTPS is auto-selected when SMTP_HOST is Brevo.
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=<your-smtp-login>
SMTP_PASS=<your-brevo-xsmtpsib-key>
SMTP_FROM=Kloqra <noreply@yourdomain.com>
BREVO_API_KEY=<your-brevo-xkeysib-api-key>
# EMAIL_TRANSPORT=brevo_api

# --- Vercel client (kloqra-client-staging, root apps/client) ---
NEXT_PUBLIC_API_BASE_URL=https://<staging-api>.up.railway.app
NEXT_PUBLIC_AUTH_SCOPE=client
NEXT_PUBLIC_HARD_AUTO_STOP_HOURS=12
NEXT_PUBLIC_CLIENT_COMMERCIAL_FEATURES=false

# --- Vercel admin (kloqra-admin-staging, root apps/admin) ---
NEXT_PUBLIC_API_BASE_URL=https://<staging-api>.up.railway.app
NEXT_PUBLIC_AUTH_SCOPE=admin
NEXT_PUBLIC_ADMIN_URL=https://kloqra-admin-staging.vercel.app
NEXT_PUBLIC_CLIENT_COMMERCIAL_FEATURES=false
